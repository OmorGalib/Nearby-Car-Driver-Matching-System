                  "    pm.expect(jsonData.success).to.be.false;",
                  "    pm.expect(jsonData.message || jsonData.error).to.exist;",
                  "    console.log('✅ Unauthorized access properly rejected');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
