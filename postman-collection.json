              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"pickup_lat\": 23.8103,\n    \"pickup_lng\": 90.4125,\n    \"radius_km\": 5\n}"
            },
            "url": {
              "raw": "{{base_url}}/ride/request",
              "host": ["{{base_url}}"],
              "path": ["ride", "request"]
            }
          }
        },
        {
          "name": "Radius Too Large",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Handles large radius gracefully', function() {",
                  "    pm.response.to.have.status(200);",
                  "    const jsonData = pm.response.json();",
                  "    console.log(`🌍 Search radius: ${jsonData.radius_km}km, Found: ${jsonData.total_drivers_found} drivers`);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{auth_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
